{
  "extends": [
    "@commitlint/config-conventional"
  ],
  "rules": {
    "body-full-stop": [
      2,
      "never",
      "."
    ],
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "test",
        "chore",
        "build",
        "ci",
        "perf",
        "revert"
      ]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "rooms",
        "questions",
        "audio",
        "gemini",
        "database",
        "infra",
        "env",
        "config",
        "dto",
        "entity",
        "tooling",
        "docker",
        "seed"
      ]
    ],
    "subject-case": [
      2,
      "never",
      [
        "start-case",
        "pascal-case",
        "upper-case"
      ]
    ],
    "subject-full-stop": [
      2,
      "never",
      "."
    ]
  }
}
